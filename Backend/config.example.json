{
    "app": {
        "port": 3000,
        "name": "Dynamic Link Directory"
    },
    "logging": {
        "message": {
            "log_directory": "./logs",
            "log_file_prefix": "message_",
            "log_file_postfix": "",
            "log_to_file": true,
            "log_to_console": true,
            "log_to_database": false
        },
        "request": {
            "log_directory": "./logs",
            "log_file_prefix": "requests_",
            "log_file_postfix": "",
            "log_to_file": true,
            "log_to_console": false,
            "log_to_database": false
        },
        "fastify": false,
        "sequelize": {
            "benchmark": true,
            "log_directory": "./logs",
            "log_file_prefix": "queries_",
            "log_file_postfix": "",
            "log_to_file": true,
            "log_to_console": false
        }
    },
    "auth": {
        "session_ttl_hours": 168,
        "login_rate_limit": {
            "max_attempts": 5,
            "window_minutes": 15,
            "lockout_minutes": 15
        },
        "default_admin": {
            "username": "admin",
            "password": "change-me",
            "display_name": "Administrator"
        },
        "azure": {
            "enabled": false,
            "tenant_id": "",
            "client_id": "",
            "audience": "",
            "auto_provision": true
        }
    },
    "database": {
        "enabled": false,
        "sync": {
            "force": false,
            "alter": false
        },
        "seed": {
            "force_dld_sync": false
        },
        "connection": {
            "username": "",
            "password": "",
            "database": "",
            "schemas": {
                "parent": "public",
                "project": "dld_dev"
            },
            "host": "127.0.0.1",
            "port": 5432,
            "dialect": "postgres"
        }
    }
}
